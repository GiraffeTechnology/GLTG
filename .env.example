# GLTG -- Giraffe Lead-Time Graph standalone service
#
# The core Python library needs no environment variables (all configuration is
# passed via request/object inputs). These variables configure the HTTP service.

GLTG_HOST=0.0.0.0
GLTG_PORT=8090
GLTG_API_VERSION=v1
GLTG_LOG_LEVEL=INFO

# aivan integration (supplier signal iteration)
AIVAN_BASE_URL=http://localhost:8765
AIVAN_TIMEOUT=30

# ---------------------------------------------------------------------------
# GLTG provider-agnostic LLM-assisted evaluator
# ---------------------------------------------------------------------------
# Qwen3.5 is the default bundled/reference evaluator backend, but GLTG is
# provider-agnostic. Switch GLTG_LLM_PROVIDER to use any mainstream LLM via its
# adapter without changing GLTG business logic.
#
# evaluator mode: llm | fallback | mock
GLTG_EVALUATOR_MODE=llm
# provider: qwen | openai_compatible | anthropic | gemini | deepseek | local | mock
GLTG_LLM_PROVIDER=qwen
GLTG_LLM_MODEL=qwen3.5
GLTG_LLM_BASE_URL=
GLTG_LLM_API_KEY=
GLTG_LLM_TIMEOUT_SECONDS=30
GLTG_LLM_MAX_RETRIES=2
GLTG_LLM_TEMPERATURE=0
GLTG_LLM_JSON_MODE=true
GLTG_LLM_STRICT_SCHEMA=true
# If the LLM provider fails and this is false, GLTG returns a controlled
# manual-review assessment instead of silently using hard-coded formulas.
GLTG_ALLOW_RULE_FALLBACK=false
# Deterministic mock scenario for CI/local testing (mock provider only).
GLTG_MOCK_SCENARIO=valid
